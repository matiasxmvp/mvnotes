{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MVNOTES",
  "version": "1.1.0",
  "identifier": "com.pizarra.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MVNOTES",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true,
        "focus": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "devtools": true,
        "dragDropEnabled": false
      },
      {
        "label": "quick",
        "title": "MVNOTES — Captura rápida",
        "url": "index.html?window=quick",
        "width": 560,
        "height": 540,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false,
        "devtools": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: asset: http://asset.localhost https://cdn.tldraw.com; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data: https://cdn.tldraw.com; connect-src 'self' ipc: http://ipc.localhost https://api.deepgram.com https://api.groq.com https://cdn.tldraw.com",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:pizarra.db"]
    }
  }
}
